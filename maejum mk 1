<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>학교 매점 실시간 혼잡도</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Malgun Gothic', sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            background-color: #ffffff;
            width: 100%;
            max-width: 450px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            padding: 30px;
            text-align: center;
        }

        h1 {
            font-size: 1.6rem;
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .time-info {
            font-size: 1.1rem;
            color: #7f8c8d;
            margin-bottom: 25px;
            padding: 8px;
            background-color: #edf2f7;
            border-radius: 8px;
            display: inline-block;
        }

        /* 혼잡도 카드 스타일 */
        .status-card {
            padding: 30px 20px;
            border-radius: 12px;
            margin-bottom: 25px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        /* 상태별 색상 디자인 */
        .status-smooth {
            background-color: #e8f5e9;
            color: #2e7d32;
            border: 2px solid #a5d6a7;
        }
        .status-normal {
            background-color: #fffde7;
            color: #f57f17;
            border: 2px solid #fff59d;
        }
        .status-crowded {
            background-color: #ffebee;
            color: #c62828;
            border: 2px solid #ffcdd2;
        }

        .status-title {
            font-size: 2.5rem;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .status-desc {
            font-size: 1.1rem;
        }

        .data-details {
            text-align: left;
            background-color: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            font-size: 0.95rem;
            border-left: 4px solid #3498db;
        }

        .data-details p {
            margin-bottom: 6px;
        }
        .data-details p:last-child {
            margin-bottom: 0;
        }

        .highlight {
            font-weight: bold;
            color: #2980b9;
        }

        footer {
            margin-top: 25px;
            font-size: 0.8rem;
            color: #bdc3c7;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>🏪 매점 실시간 혼잡도</h1>
        <div class="time-info" id="current-time-display">시간 계산 중...</div>

        <div id="status-box" class="status-card status-smooth">
            <div class="status-title" id="status-text">계산 중</div>
            <div class="status-desc" id="status-desc">데이터를 불러오는 중입니다.</div>
        </div>

        <div class="data-details">
            <p>📊 <span id="info-period">현재 교시</span> 쉬는시간 기준</p>
            <p>👥 예상 방문 학생 수: <span id="predicted-count" class="highlight">0</span>명</p>
        </div>

        <footer>* 본 정보는 요일/교시별 평균 예측 데이터 기반입니다.</footer>
    </div>

    <script>
        // 1. 요일 및 교시별 예상 학생 수 데이터 정의 (원하는 대로 숫자 수정 가능)
        // 1교시부터 7교시까지의 쉬는시간 데이터 예시입니다.
        const timetableData = {
            "월요일": [45, 55, 25, 70, 40, 60, 30], // 1교시, 2교시, 3교시, 4교시, 5교시, 6교시, 7교시 쉬는시간 순서
            "화요일": [35, 40, 65, 80, 20, 50, 15],
            "수요일": [50, 60, 30, 75, 45, 55, 20],
            "목요일": [40, 45, 55, 85, 30, 65, 25],
            "금요일": [60, 70, 40, 90, 50, 45, 10]
        };

        // 2. 학교 시간표 설정 (교시별 시작 및 종료 시간 정의)
        // 학교의 실제 시간표(쉬는시간 포함)에 맞게 아래 시간을 수정하세요!
        function getCurrentPeriod(hours, minutes) {
            const timeInMinutes = hours * 60 + minutes;

            // 예시 시간표 (분 단위 환산 처리)
            // 1교시 쉬는시간: 09:50 ~ 10:00 (590분 ~ 600분)
            // 아래 조건문은 '해당 교시가 시작된 후 ~ 다음 교시 시작 전'을 기준으로 넓게 잡았습니다.
            if (timeInMinutes >= 540 && timeInMinutes < 600) return { name: "1교시", index: 0 };
            if (timeInMinutes >= 600 && timeInMinutes < 660) return { name: "2교시", index: 1 };
            if (timeInMinutes >= 660 && timeInMinutes < 720) return { name: "3교시", index: 2 };
            if (timeInMinutes >= 720 && timeInMinutes < 810) return { name: "4교시", index: 3 }; // 점심시간 포함 가정
            if (timeInMinutes >= 810 && timeInMinutes < 870) return { name: "5교시", index: 4 };
            if (timeInMinutes >= 870 && timeInMinutes < 930) return { name: "6교시", index: 5 };
            if (timeInMinutes >= 930 && timeInMinutes < 1020) return { name: "7교시", index: 6 };

            return { name: "정규 수업 외 시간", index: -1 };
        }

        // 3. 실시간 분석 및 화면 업데이트 함수
        function updateCongestion() {
            const now = new Date();
            
            // 실제 요일 구하기
            const weekDays = ["일요일", "월요일", "화요일", "수요일", "목요일", "금요일", "토요일"];
            const currentDayStr = weekDays[now.getDay()]; 
            
            const hours = now.getHours();
            const minutes = now.getMinutes();
            
            // 화면에 현재 시각 표시
            const timeStr = `${currentDayStr} ${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
            document.getElementById('current-time-display').innerText = `현재 시각: ${timeStr}`;

            // 주말 예외 처리
            if (currentDayStr === "토요일" || currentDayStr === "일요일") {
                showStatus("영업 종료", "주말에는 매점을 운영하지 않습니다.", 0, "status-smooth", "주말");
                return;
            }

            // 현재 교시 파악
            const periodInfo = getCurrentPeriod(hours, minutes);
            
            if (periodInfo.index === -1) {
                showStatus("운영 외", "현재는 정규 쉬는시간이 아닙니다.", 0, "status-smooth", "기타 시간");
                return;
            }

            // 해당 요일 및 교시의 예측 데이터 가져오기
            const dayData = timetableData[currentDayStr];
            const predictedCount = dayData[periodInfo.index];

            // 4. 기준에 따른 혼잡도 판별
            let statusText = "";
            let statusDesc = "";
            let statusClass = "";

            if (predictedCount <= 35) {
                statusText = "여 유";
                statusDesc = "매점이 한산합니다. 편하게 이용하세요! 🟢";
                statusClass = "status-smooth";
            } else if (predictedCount <= 65) {
                statusText = "보 통";
                statusDesc = "대기 줄이 조금 있을 수 있습니다. 🟡";
                statusClass = "status-normal";
            } else {
                statusText = "혼 잡";
                statusDesc = "사람이 많아 매우 혼잡합니다. 다음 시간에 방문하는 걸 추천해요! 🔴";
                statusClass = "status-crowded";
            }

            showStatus(statusText, statusDesc, predictedCount, statusClass, `${currentDayStr} ${periodInfo.name}`);
        }

        // 화면 갱신 보조 함수
        function showStatus(text, desc, count, className, periodName) {
            const statusBox = document.getElementById('status-box');
            statusBox.className = `status-card ${className}`;
            
            document.getElementById('status-text').innerText = text;
            document.getElementById('status-desc').innerText = desc;
            document.getElementById('predicted-count').innerText = count;
            document.getElementById('info-period').innerText = periodName;
        }

        // 페이지 로드 시 즉시 실행
        updateCongestion();
    </script>
</body>
</html>
